UNION ALL
SELECT CAST(NULL AS VARCHAR) AS REVIEW_ID, CAST(NULL AS VARCHAR) AS REVIEW_TEXT, CAST('2025-01-14' AS TIMESTAMP_NTZ(9)) AS REVIEW_DATE, CAST(NULL AS NUMBER) AS LISTING_ID, CAST(NULL AS VARCHAR) AS REVIEWER_NAME, CAST(NULL AS VARCHAR) AS REVIEW_SENTIMENT, CAST('not full moon' AS VARCHAR) AS IS_FULL_MOON
UNION ALL

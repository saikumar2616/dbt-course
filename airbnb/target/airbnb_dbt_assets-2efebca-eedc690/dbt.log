{"data": {"conn_name": "model.airbnb.dim_hosts_cleansed", "node_info": {"materialized": "view", "meta": {}, "node_checksum": "e1ddad4e8be42a1b03916ee1bd4a8afdcc5dfd7e965f6b3aab1bde8876d2ca1b", "node_finished_at": "", "node_name": "dim_hosts_cleansed", "node_path": "dim/dim_hosts_cleansed.sql", "node_relation": {"alias": "dim_hosts_cleansed", "database": "AIRBNB", "relation_name": "AIRBNB.DEV.dim_hosts_cleansed", "schema": "DEV"}, "node_started_at": "2026-03-18T02:27:59.125032", "node_status": "executing", "resource_type": "model", "unique_id": "model.airbnb.dim_hosts_cleansed"}, "sql": "select * from (\n        \nWITH  __dbt__cte__src_hosts as (\nWITH raw_hosts AS (\n    SELECT\n        *\n    FROM\n       AIRBNB.raw.raw_hosts\n)\nSELECT\n    id AS host_id,\n    name AS host_name,\n    is_superhost,\n    created_at,\n    updated_at\nFROM\n    raw_HOSTS\n), src_hosts AS (\n    SELECT\n        *\n    FROM\n        __dbt__cte__src_hosts\n)\nSELECT\n    host_id,\n    NVL(\n        host_name,\n        'Anonymous'\n    ) AS host_name,\n    is_superhost,\n    created_at,\n    updated_at\nFROM\n    src_hosts\n    ) as __dbt_sbq\n    where false\n    limit 0\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.2\", \"profile_name\": \"airbnb\", \"target_name\": \"dev\", \"node_id\": \"model.airbnb.dim_hosts_cleansed\"} */\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.2\", \"profile_name\": \"airbnb\", \"target_name\": \"dev\", \"node_id\": \"model.airbnb.dim_hosts_cleansed\"} */"}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "acbdabd6-c135-49db-b000-2ae95d7b8aa6", "level": "debug", "msg": "On model.airbnb.dim_hosts_cleansed: select * from (\n        \nWITH  __dbt__cte__src_hosts as (\nWITH raw_hosts AS (\n    SELECT\n        *\n    FROM\n       AIRBNB.raw.raw_hosts\n)\nSELECT\n    id AS host_id,\n    name AS host_name,\n    is_superhost,\n    created_at,\n    updated_at\nFROM\n    raw_HOSTS\n), src_hosts AS (\n    SELECT\n        *\n    FROM\n        __dbt__cte__src_hosts\n)\nSELECT\n    host_id,\n    NVL(\n        host_name,\n        'Anonymous'\n    ) AS host_name,\n    is_superhost,\n    created_at,\n    updated_at\nFROM\n    src_hosts\n    ) as __dbt_sbq\n    where false\n    limit 0\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.2\", \"profile_name\": \"airbnb\", \"target_name\": \"dev\", \"node_id\": \"model.airbnb.dim_hosts_cleansed\"} */\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.2\", \"profile_name\": \"airbnb\", \"target_name\": \"dev\", \"node_id\": \"model.airbnb.dim_hosts_cleansed\"} */", "name": "SQLQuery", "pid": 31759, "thread": "Thread-2 (worker)", "ts": "2026-03-18T02:27:59.242295Z"}}

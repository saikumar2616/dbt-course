{"data": {"conn_name": "model.airbnb.dim_listings_cleansed", "node_info": {"materialized": "view", "meta": {}, "node_checksum": "6bd2b96d1c0b217e6bab23a6f5214edeaafc6c587503d9413878660fcd509ebb", "node_finished_at": "", "node_name": "dim_listings_cleansed", "node_path": "dim/dim_listings_cleansed.sql", "node_relation": {"alias": "dim_listings_cleansed", "database": "AIRBNB", "relation_name": "AIRBNB.DEV.dim_listings_cleansed", "schema": "DEV"}, "node_started_at": "2026-03-18T02:28:00.774852", "node_status": "executing", "resource_type": "model", "unique_id": "model.airbnb.dim_listings_cleansed"}, "sql": "create or replace   view AIRBNB.DEV.dim_listings_cleansed\n  \n  \n  \n  \n  as (\n    \nWith  __dbt__cte__src_listings as (\nWITH raw_listings AS (\n    SELECT\n        *\n    FROM\n        AIRBNB.raw.raw_listings\n)\nSELECT\n    id AS listing_id,\n    name AS listing_name,\n    listing_url,\n    room_type,\n    minimum_nights,\n    host_id,\n    price AS price_str,\n    created_at,\n    updated_at\nFROM\n    raw_listings\n), src_listings as (\n    SELECT\n        *\n    FROM\n       __dbt__cte__src_listings\n       )\nSELECT\n  listing_id,\n  listing_name,\n  room_type,\n  CASE\n    WHEN minimum_nights = 0 THEN 1\n    ELSE minimum_nights\n  END AS minimum_nights,\n  host_id,\n  REPLACE(\n    price_str,\n    '$'\n  ) :: NUMBER(\n    10,\n    2\n  ) AS price,\n  created_at,\n  updated_at\nFROM\n  src_listings\n  )\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.2\", \"profile_name\": \"airbnb\", \"target_name\": \"dev\", \"node_id\": \"model.airbnb.dim_listings_cleansed\"} */;"}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "acbdabd6-c135-49db-b000-2ae95d7b8aa6", "level": "debug", "msg": "On model.airbnb.dim_listings_cleansed: create or replace   view AIRBNB.DEV.dim_listings_cleansed\n  \n  \n  \n  \n  as (\n    \nWith  __dbt__cte__src_listings as (\nWITH raw_listings AS (\n    SELECT\n        *\n    FROM\n        AIRBNB.raw.raw_listings\n)\nSELECT\n    id AS listing_id,\n    name AS listing_name,\n    listing_url,\n    room_type,\n    minimum_nights,\n    host_id,\n    price AS price_str,\n    created_at,\n    updated_at\nFROM\n    raw_listings\n), src_listings as (\n    SELECT\n        *\n    FROM\n       __dbt__cte__src_listings\n       )\nSELECT\n  listing_id,\n  listing_name,\n  room_type,\n  CASE\n    WHEN minimum_nights = 0 THEN 1\n    ELSE minimum_nights\n  END AS minimum_nights,\n  host_id,\n  REPLACE(\n    price_str,\n    '$'\n  ) :: NUMBER(\n    10,\n    2\n  ) AS price,\n  created_at,\n  updated_at\nFROM\n  src_listings\n  )\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.2\", \"profile_name\": \"airbnb\", \"target_name\": \"dev\", \"node_id\": \"model.airbnb.dim_listings_cleansed\"} */;", "name": "SQLQuery", "pid": 31759, "thread": "Thread-2 (worker)", "ts": "2026-03-18T02:28:00.829411Z"}}

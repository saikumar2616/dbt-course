{"data": {"conn_name": "test.airbnb.consistent_created_at", "node_info": {"materialized": "test", "meta": {}, "node_checksum": "222be667831002b0e9862badcffc34ba435b750ca86186ff2cc4e11ae16d6d3e", "node_finished_at": "", "node_name": "consistent_created_at", "node_path": "consistent_created_at.sql", "node_relation": {"alias": "consistent_created_at", "database": "AIRBNB", "relation_name": "AIRBNB.DEV_test_audit.consistent_created_at", "schema": "DEV_test_audit"}, "node_started_at": "2026-03-18T02:16:33.538658", "node_status": "executing", "resource_type": "test", "unique_id": "test.airbnb.consistent_created_at"}, "sql": "create or replace transient table AIRBNB.DEV_test_audit.consistent_created_at\n    \n    \n    \n    as (\n    \n  select * from AIRBNB.DEV.fct_reviews f inner join AIRBNB.DEV.dim_listings_cleansed l\n--on f.listing_id = l.listing_id\nUSING (listing_id)\nwhere f.review_date <  l.created_at \n--  This sql should return 0 rows as review_date should always be greater than created_at.\n-- If it returns more than 0 rows, then there is an issue with the created_at field in dim_listings_cleansed model.\n  \n  \n    )\n\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.2\", \"profile_name\": \"airbnb\", \"target_name\": \"dev\", \"node_id\": \"test.airbnb.consistent_created_at\"} */;"}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "f6fb9759-b1d4-40bf-ad49-a9799e6a0323", "level": "debug", "msg": "On test.airbnb.consistent_created_at: create or replace transient table AIRBNB.DEV_test_audit.consistent_created_at\n    \n    \n    \n    as (\n    \n  select * from AIRBNB.DEV.fct_reviews f inner join AIRBNB.DEV.dim_listings_cleansed l\n--on f.listing_id = l.listing_id\nUSING (listing_id)\nwhere f.review_date <  l.created_at \n--  This sql should return 0 rows as review_date should always be greater than created_at.\n-- If it returns more than 0 rows, then there is an issue with the created_at field in dim_listings_cleansed model.\n  \n  \n    )\n\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.2\", \"profile_name\": \"airbnb\", \"target_name\": \"dev\", \"node_id\": \"test.airbnb.consistent_created_at\"} */;", "name": "SQLQuery", "pid": 16121, "thread": "Thread-2 (worker)", "ts": "2026-03-18T02:16:33.643101Z"}}

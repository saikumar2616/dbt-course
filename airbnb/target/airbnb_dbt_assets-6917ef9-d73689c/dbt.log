{"data": {"conn_name": "unit_test.airbnb.mart_full_moon_reviews.unittest_fullmoon_matcher", "node_info": {"materialized": "", "meta": {}, "node_checksum": "", "node_finished_at": "", "node_name": "unittest_fullmoon_matcher", "node_path": "mart/unit_tests.yaml", "node_relation": {"alias": "", "database": "", "relation_name": "", "schema": "DEV"}, "node_started_at": "2026-03-18T02:16:28.519791", "node_status": "executing", "resource_type": "unit_test", "unique_id": "unit_test.airbnb.mart_full_moon_reviews.unittest_fullmoon_matcher"}, "sql": "-- Build actual result given inputs\nwith dbt_internal_unit_test_actual as (\n  select\n    \"REVIEW_DATE\",\"IS_FULL_MOON\", 'actual' as \"actual_or_expected\"\n  from (\n    \n\nWITH  __dbt__cte__fct_reviews as (\n\n-- Fixture for fct_reviews\nselect try_cast(null as character varying(32)) as \"REVIEW_ID\", try_cast(null as character varying(16777216)) as \"REVIEW_TEXT\", \n    \n        try_cast('2025-01-13' as TIMESTAMP_NTZ)\n     as \"REVIEW_DATE\", try_cast(null as NUMBER(38,0)) as \"LISTING_ID\", try_cast(null as character varying(16777216)) as \"REVIEWER_NAME\", try_cast(null as character varying(16777216)) as \"REVIEW_SENTIMENT\"\nunion all\nselect try_cast(null as character varying(32)) as \"REVIEW_ID\", try_cast(null as character varying(16777216)) as \"REVIEW_TEXT\", \n    \n        try_cast('2025-01-14' as TIMESTAMP_NTZ)\n     as \"REVIEW_DATE\", try_cast(null as NUMBER(38,0)) as \"LISTING_ID\", try_cast(null as character varying(16777216)) as \"REVIEWER_NAME\", try_cast(null as character varying(16777216)) as \"REVIEW_SENTIMENT\"\nunion all\nselect try_cast(null as character varying(32)) as \"REVIEW_ID\", try_cast(null as character varying(16777216)) as \"REVIEW_TEXT\", \n    \n        try_cast('2025-01-15' as TIMESTAMP_NTZ)\n     as \"REVIEW_DATE\", try_cast(null as NUMBER(38,0)) as \"LISTING_ID\", try_cast(null as character varying(16777216)) as \"REVIEWER_NAME\", try_cast(null as character varying(16777216)) as \"REVIEW_SENTIMENT\"\n),  __dbt__cte__seed_full_moon_dates as (\n\n-- Fixture for seed_full_moon_dates\nselect \n    \n        try_cast('2025-01-14' as DATE)\n     as \"FULL_MOON_DATE\"\n), fct_reviews AS (\n    SELECT * FROM __dbt__cte__fct_reviews\n),\nfull_moon_dates AS (\n    SELECT * FROM __dbt__cte__seed_full_moon_dates\n)\n\nSELECT\n  r.*,\n  CASE\n    WHEN fm.full_moon_date IS NULL THEN 'not full moon'\n    ELSE 'full moon'\n  END AS is_full_moon\nFROM\n  fct_reviews\n  r\n  LEFT JOIN full_moon_dates\n  fm\n  ON (TO_DATE(r.review_date) = DATEADD(DAY, 1, fm.full_moon_date))\n  ) _dbt_internal_unit_test_actual\n),\n-- Build expected result\ndbt_internal_unit_test_expected as (\n  select\n    \"REVIEW_DATE\", \"IS_FULL_MOON\", 'expected' as \"actual_or_expected\"\n  from (\n    select \n    \n        try_cast('2025-01-13' as TIMESTAMP_NTZ)\n     as \"REVIEW_DATE\", \n    \n        try_cast('not full moon' as character varying(13))\n     as \"IS_FULL_MOON\"\nunion all\nselect \n    \n        try_cast('2025-01-14' as TIMESTAMP_NTZ)\n     as \"REVIEW_DATE\", \n    \n        try_cast('not full moon' as character varying(13))\n     as \"IS_FULL_MOON\"\nunion all\nselect \n    \n        try_cast('2025-01-15' as TIMESTAMP_NTZ)\n     as \"REVIEW_DATE\", \n    \n        try_cast('full moon' as character varying(13))\n     as \"IS_FULL_MOON\"\n  ) _dbt_internal_unit_test_expected\n)\n-- Union actual and expected results\nselect * from dbt_internal_unit_test_actual\nunion all\nselect * from dbt_internal_unit_test_expected\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.2\", \"profile_name\": \"airbnb\", \"target_name\": \"dev\", \"node_id\": \"unit_test.airbnb.mart_full_moon_reviews.unittest_fullmoon_matcher\"} */"}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "f6fb9759-b1d4-40bf-ad49-a9799e6a0323", "level": "debug", "msg": "On unit_test.airbnb.mart_full_moon_reviews.unittest_fullmoon_matcher: -- Build actual result given inputs\nwith dbt_internal_
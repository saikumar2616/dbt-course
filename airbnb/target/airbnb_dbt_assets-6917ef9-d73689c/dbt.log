{"data": {"conn_name": "model.airbnb.dim_listings_with_hosts", "node_info": {"materialized": "table", "meta": {}, "node_checksum": "1a16123121acc39a142cf1e0e23d2952e52b7a58edeb4e99581c0c9a1fa6aaa6", "node_finished_at": "", "node_name": "dim_listings_with_hosts", "node_path": "dim/dim_listings_with_hosts.sql", "node_relation": {"alias": "dim_listings_with_hosts", "database": "AIRBNB", "relation_name": "AIRBNB.DEV.dim_listings_with_hosts", "schema": "DEV"}, "node_started_at": "2026-03-18T02:16:39.005895", "node_status": "executing", "resource_type": "model", "unique_id": "model.airbnb.dim_listings_with_hosts"}, "sql": "create or replace transient table AIRBNB.DEV.dim_listings_with_hosts\n    \n    \n    \n    as (WITH\nl AS (\n    SELECT\n        *\n    FROM\n        AIRBNB.DEV.dim_listings_cleansed\n),\nh AS (\n    SELECT *\n    FROM AIRBNB.DEV.dim_hosts_cleansed\n)\n\nSELECT\n    l.listing_id,\n    l.listing_name,\n    l.room_type,\n    l.minimum_nights,\n    l.price,\n    l.host_id,\n    h.host_name,\n    h.is_superhost as host_is_superhost,\n    l.created_at,\n    GREATEST(l.updated_at, h.updated_at) as updated_at\nFROM l\nLEFT JOIN h ON (h.host_id = l.host_id)\n    )\n\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.2\", \"profile_name\": \"airbnb\", \"target_name\": \"dev\", \"node_id\": \"model.airbnb.dim_listings_with_hosts\"} */;"}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "f6fb9759-b1d4-40bf-ad49-a9799e6a0323", "level": "debug", "msg": "On model.airbnb.dim_listings_with_hosts: create or replace transient table AIRBNB.DEV.dim_listings_with_hosts\n    \n    \n    \n    as (WITH\nl AS (\n    SELECT\n        *\n    FROM\n        AIRBNB.DEV.dim_listings_cleansed\n),\nh AS (\n    SELECT *\n    FROM AIRBNB.DEV.dim_hosts_cleansed\n)\n\nSELECT\n    l.listing_id,\n    l.listing_name,\n    l.room_type,\n    l.minimum_nights,\n    l.price,\n    l.host_id,\n    h.host_name,\n    h.is_superhost as host_is_superhost,\n    l.created_at,\n    GREATEST(l.updated_at, h.updated_at) as updated_at\nFROM l\nLEFT JOIN h ON (h.host_id = l.host_id)\n    )\n\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.11.2\", \"profile_name\": \"airbnb\", \"target_name\": \"dev\", \"node_id\": \"model.airbnb.dim_listings_with_hosts\"} */;", "name": "SQLQuery", "pid": 16121, "thread": "Thread-2 (worker)", "ts": "2026-03-18T02:16:39.027051Z"}}
